# ============================================================
#  GLG Property — variabile de mediu
#  Copiază acest fișier în `.env.local` și completează valorile.
#  NU urca niciodată .env.local în git.
# ============================================================

# --- Supabase ---
# URL-ul proiectului tău Supabase (ex: https://xxxxxxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# Cheia publică `anon` (poate ajunge în browser; e protejată de RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Cheia `service_role` — SECRET. RĂMÂNE DOAR PE SERVER. Nu o expune niciodată în browser!
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Sesiune ---
# Secret folosit pentru semnarea cookie-ului de sesiune (JWT HS256).
# Generează unul lung și aleatoriu, ex: `openssl rand -base64 48`
SESSION_SECRET=schimba-ma-cu-un-secret-lung-si-aleatoriu

# --- Notificări (opțional — modulul se poate dezactiva) ---
# Pune ON ca să activezi trimiterea reală de notificări. Orice altceva = dezactivat (rămân in-app).
NOTIFICATIONS_ENABLED=off
# Token-ul botului Telegram (de la @BotFather). Lasă gol dacă nu folosești Telegram.
TELEGRAM_BOT_TOKEN=
# Token-ul botului Viber (din Viber Admin Panel). Lasă gol dacă nu folosești Viber.
VIBER_BOT_TOKEN=

# --- Securitate cron notificări ---
# Secret pentru a proteja endpoint-ul de trimitere remindere (/api/cron/reminders).
# Apelantul (cron job) trebuie să trimită header-ul: Authorization: Bearer <CRON_SECRET>
CRON_SECRET=schimba-ma-cu-alt-secret

# --- General ---
# URL-ul public al aplicației (folosit în mesaje/linkuri). Ex: https://glg.exemplu.ro
NEXT_PUBLIC_APP_URL=http://localhost:3000
